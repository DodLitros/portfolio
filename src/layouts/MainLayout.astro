---
import { ClientRouter } from 'astro:transitions';
import Navbar from "../components/Navbar.astro";
import "../styles/global.css";
import BubbleField from './BubbleField.astro';
import Background from '../components/Background.astro';

const  { title } = Astro.props;

interface props {
	title: string;
	age?: number;
	isActive?: boolean; 
}
---

<html lang="en">		
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ClientRouter />
	</head>
	<body>
		 <!-- <Background  BackgroundSketch client:idle /> -->
		<div class="min-h-screen grid grid-rows-[60vh_30vh_10vh] gap-4 p-4">

			<!-- TOP SECTION -->
			<div class="grid grid-cols-3 gap-4">	
				
				<!-- LEFT (2/3) -->
				<div class="col-span-2 border-2 border-black flex items-center justify-center">
					<div class="w-full h-full">
						<BubbleField />
					</div>
				</div>

				<!-- RIGHT (1/3) -->
				<div class="border-2 border-black flex items-center justify-center">
				<slot name="visual" />
				</div>

			</div>

			<!-- MIDDLE DESCRIPTION -->
			<div class="border-2 border-black flex items-center justify-center text-center">
				<slot name="description" />
			</div>

			<!-- FOOTER NAV -->
			<div class="flex justify-center">
				<div class="border-2 border-black px-10 py-4">
				<slot name="footer" />
				</div>
			</div>

		</div>

    </body>
</html>
