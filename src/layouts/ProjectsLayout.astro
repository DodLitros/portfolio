---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import AboutMe from "../components/AboutMe.astro";
import Pic from "../components/Pic.astro";

const { title } = Astro.props;

interface props {
  title: string;
  age?: number;
  isActive?: boolean;
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <div class="min-h-screen grid grid-rows-[60vh_30vh_10vh] gap-4 p-4">
      <!-- TOP SECTION -->
      <div class="grid grid-cols-3 gap-4">
        <!-- LEFT (2/3) -->
        <div class="col-span-2 flex items-center justify-center">
          <div class="w-full h-full">
            
          </div>
        </div>

        <!-- RIGHT (1/3) -->
        <div class="flex items-center justify-center">
          <div class="w-full h-full">
						<Pic/>		
					</div>
        </div>
      </div>

      <!-- MIDDLE DESCRIPTION -->
      <AboutMe>
        <p slot="description">
          Soy desarrollador y ya porque no me limito al software o hardware, yo me encargo de <strong>crear</strong> de <strong>construir</strong> ideas que solucionen tus problemas
          <br />
          estudié <strong>Ingeniería física</strong> con la esperanza de ser un inventor, y aquí es donde radica mi creatividad.
        </p>
      </AboutMe>

      <!-- FOOTER NAV -->
      <div class="flex justify-center">
        <div class="border-2 border-black px-10 py-4">
          <slot name="footer" />
        </div>
      </div>
    </div>
  </body>
</html>
