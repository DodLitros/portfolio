---
import Redes from "./Redes.astro";

const message = encodeURIComponent(
  "Hola Carlitos, estoy interesado en trabajar contigo!"
);

const whatsappLink = `https://wa.me/573505484336?text=${message}`;
---
<div class="card" id="card">
  <div class="face front" >
    <div class="card-front">
      <div class="banner" onclick="flip()">
      <a href={whatsappLink}>
        <span class="banner-text" >CONTACTAME</span>
        <span class="banner-text" >CLICK ME</span>
      </a>
    </div>
    <span class="card__title">Desarrollador</span>
    <div class="card__image-wrap">
      <img src="../../character.png" alt="Silueta de desarrollador" />
    </div>

    </div>
  </div>
  <Redes/>
</div>

<style>
  /* @media (max-width: 768px){
    .card{
      height: 100%;
    }
  } */
  .card {
    width: 100%;
    max-width: 380px;
    height: 105%;
    position: relative;
    transform-style: preserve-3d;
    transition: transform 0.6s ease;
  }
  .card.flipped {
    transform: rotateY(180deg);
  }
  .face {
    position: absolute;
    width: 100%;
    height: 100%;
    backface-visibility: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  img{
  height: auto;
    display: block;
    object-fit:cover;
    
  }

  .card__image-wrap {
    width: 100%;
    height: auto;
    position: absolute;
    bottom: 0;
    overflow: hidden;  
    background: #FF4F00 ; 
    display: flex; 
    justify-content: center;
    align-items: flex-start; 
  }

  .card__image-wrap img {
    width: 100%; 
    height: fit-content; 
    bottom: 0; 
    object-fit:cover; 
    object-position: center top; 
  }

  .card-front {
    width: 100%;
    height: 100%;
    /* padding: 30px; */
    background: #FF4F00 ;
    border: 8px solid #000;
    box-shadow: 15px 15px 0 #000;
    transform: rotate(-2deg);
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }
  .card-front:active {
    animation: shake 0.5s ease-in-out;
  }
  .card-front:hover {
    transform: rotate(0deg) scale(1.02);
    box-shadow: 20px 20px 0 #000;
  }
  .banner {
      z-index: 2;
      position: absolute;
      top: 3px;
      right: -95px;
      background: #000;
      color: #fff;
      padding: 15px;
      width: 400px;
      height: 50px;
      text-align: center;
      transform: rotate(45deg);
      font-weight: bold;
      font-size: 1.5rem;
      letter-spacing: 2px;
      overflow: hidden;
      transition: background 0.5s ease;
      cursor: pointer;
  }
  .banner-text {
    display: inline-block;
    transition: opacity 0.5s ease, transform 0.5s ease;
    width: 100%;
    position: absolute;
    left: 13%;
    top: 50%;
    transform: translateY(-50%);
  }
  .banner:hover .banner-text:first-child {
    opacity: 0;
    transform: translateY(-100%);
  }
  .banner:hover .banner-text:last-child {
    opacity: 1;
    transform: translateY(-40%);
  }
  .banner-text:last-child {
    opacity: 0;
    transform: translateY(60%);
  }
  .banner:hover {
    background: rgb(39, 208, 87);
    text-shadow: 3px 3px 0 #000000;
  }
  .card__title {
    font-family: "Pixelify Sans", sans-serif;
    color: white;
    text-transform: uppercase;
    margin-left: 10px;
    margin-top: 50px;
    font-size: 1.9rem;
    text-shadow: 3px 3px 0px var(--black);
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 10px;
    display: block;
    border-bottom: 2px solid #000;
    width: 50%; /* or any other percentage or pixel value */
  }
  @keyframes shake {
    0% {
      transform: translateX(0);
    }
    25% {
      transform: translateX(-5px);
    }
    50% {
      transform: translateX(5px);
    }
    75% {
      transform: translateX(-5px);
    }
    100% {
      transform: translateX(0);
    }
  }
</style>