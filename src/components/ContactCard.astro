<div class="card-contact">
  <div class="card-pattern-grid"></div>
  <div class="card-overlay-dots"></div>

  <div class="card-title-area">
    <span>Contactame</span>
    <div class="feature-grid">
      <div class="feature-item">
        <div class="feature-icon">
          
        </div>
      </div>
      <div class="feature-item">
        <div class="feature-icon">
          
        </div>
      </div>
      <div class="feature-item">
        <div class="feature-icon">
         
        </div>
      </div>
      <div class="feature-item">
        <div class="feature-icon">
         
        </div>
      </div>
    </div>
  </div>

  <div class="card-body">
    <div>
      <input class="mb-5 bg-[#f7d700]" placeholder="TU NOMBRE" type="text"/ id="name">
      <input class="mb-5 bg-[#e91e63]" placeholder="TU CORREO ELECTRÓNICO" type="email"/ id="email">
      <input class="mb-5 bg-[#c084fc]" placeholder="TU NÚMERO TELEFÓNICO" type="tel"/ id="tel">
    </div>
    <textarea class="message" placeholder="Escribeme en este recuadro tu idea" name="idea" id="text"/>
    <div class="card-actions">
      <button class="card-button">Enviar propuesta</button>
    </div>
  </div>

  <div class="dots-pattern">
    <svg viewBox="0 0 80 40">
      <circle fill="#000" r="3" cy="10" cx="10"></circle>
      <circle fill="#000" r="3" cy="10" cx="30"></circle>
      <circle fill="#000" r="3" cy="10" cx="50"></circle>
      <circle fill="#000" r="3" cy="10" cx="70"></circle>
      <circle fill="#000" r="3" cy="20" cx="20"></circle>
      <circle fill="#000" r="3" cy="20" cx="40"></circle>
      <circle fill="#000" r="3" cy="20" cx="60"></circle>
      <circle fill="#000" r="3" cy="30" cx="10"></circle>
      <circle fill="#000" r="3" cy="30" cx="30"></circle>
      <circle fill="#000" r="3" cy="30" cx="50"></circle>
      <circle fill="#000" r="3" cy="30" cx="70"></circle>
    </svg>
  </div>

  <div class="accent-shape"></div>
  <div class="corner-slice"></div>

</div>

<style>
  input {
    width: 100%; 
    letter-spacing: 1.5px;
    padding: 5px;
    font-size: 13px;
    font-weight: bold;
    color: #000;
    border: 4px solid #000;
    overflow: hidden;
    border-radius: 0;
    outline: none;
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    box-shadow: 5px 5px 0 #000;
  }
  input:focus-visible{
    box-shadow: 0 0 0 black;
  }
  input::placeholder{
        font-family: "Pixelify Sans", sans-serif;
  }
  .card-contact {
    --primary: #ff3e00;
    --primary-hover: #ff6d43;
    --secondary: #4d61ff;
    --secondary-hover: #5e70ff;
    --accent: #00e0b0;
    --text: #050505;
    --bg: #ffffff;
    --shadow-color: #000000;
    --pattern-color: #cfcfcf;

    position: relative;
    width: auto;
    background: var(--bg);
    border: 0.35em solid var(--text);
    box-shadow:
      0.7em 0.7em 0 var(--shadow-color),
      inset 0 0 0 0.15em rgba(0, 0, 0, 0.05);
    transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
    overflow: hidden;
    font-family: ui-sans-serif, system-ui, sans-serif;
    transform-origin: center;
  }

  .card-contact:hover {
    transform: translate(-0.4em, -0.4em) scale(1.02);
    box-shadow: 1em 1em 0 var(--shadow-color);
  }

  .card-contact:hover .card-pattern-grid,
  .card-contact:hover .card-overlay-dots {
    opacity: 1;
  }

  .card-contact:active {
    transform: translate(0.1em, 0.1em) scale(0.98);
    box-shadow: 0.5em 0.5em 0 var(--shadow-color);
  }


  .card-pattern-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, rgba(0, 0, 0, 0.05) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(0, 0, 0, 0.05) 1px, transparent 1px);
    background-size: 0.5em 0.5em;
    pointer-events: none;
    opacity: 0.5;
    transition: opacity 0.4s ease;
    z-index: 1;
  }

  .card-overlay-dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(
      var(--pattern-color) 1px,
      transparent 1px
    );
    background-size: 1em 1em;
    background-position: -0.5em -0.5em;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: 1;
  }

  .bold-pattern {
    position: absolute;
    top: 0;
    right: 0;
    width: 6em;
    height: 6em;
    opacity: 0.15;
    pointer-events: none;
    z-index: 1;
  }

  .card-title-area {
    text-align: center;
    position: relative;
    padding: 10px;
    background: var(--primary);
    color: var(--bg);
    font-weight: 900;
    text-shadow: 2px 2px 10px black;
    font-size: 2em;
    display: flex;
    flex-direction: column ;
    justify-content: Center;
    align-items: center;
    border-bottom: 0.35em solid var(--text);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    z-index: 2;
    overflow: hidden;
  }

  .card-title-area::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: repeating-linear-gradient(
      45deg,
      rgba(0, 0, 0, 0.1),
      rgba(0, 0, 0, 0.1) 0.5em,
      transparent 0.5em,
      transparent 1em
    );
    pointer-events: none;
    opacity: 0.3;
  }

  .card-tag {
    background: var(--bg);
    color: var(--text);
    font-size: 0.6em;
    font-weight: 800;
    padding: 0.4em 0.8em;
    border: 0.15em solid var(--text);
    border-radius: 0.3em;
    box-shadow: 0.2em 0.2em 0 var(--shadow-color);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transform: rotate(3deg);
    transition: all 0.3s ease;
  }

  .card-contact:hover .card-tag {
    transform: rotate(-2deg) scale(1.1);
    box-shadow: 0.25em 0.25em 0 var(--shadow-color);
  }

  .card-body {
    position: relative;
    padding: 1.5em;
    z-index: 2;
  }
  .message{
    background-color: var(--secondary);
    padding: 5px;
    border: 3px solid black;
    margin-bottom: 1em;
    width: 100%;
    font-weight: 600;
    color: black;
    box-shadow:
      5px 5px 0 var(--shadow-color)
  }
  .message:focus-visible{
    box-shadow: 0 0 0 black;
    font-weight: 600;
    background-color: white;
    outline: #000000;
  }
  .message::placeholder{
    font-family: "Pixelify Sans", sans-serif;
    color: rgb(255, 255, 255);
    font-size: 1rem;
  }
  .feature-grid {
    display: flex;
    gap: .5em;
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: 0.6em;
    transition: transform 0.2s ease;
  }

  .feature-item:hover {
    transform: translateX(0.3em);
  }

  .feature-icon {
    width: 1em;
    height: 1em;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--secondary);
    border: 0.12em solid var(--text);
    border-radius: 0.3em;
    box-shadow: 0.2em 0.2em 0 rgba(0, 0, 0, 0.2);
    transition: all 0.2s ease;
  }

  .feature-item:hover .feature-icon {
    background: var(--secondary-hover);
    transform: rotate(-5deg);
  }

  .feature-icon svg {
    width: 0.9em;
    height: 0.9em;
    fill: var(--bg);
  }

  .feature-text {
    font-size: 0.85em;
    font-weight: 600;
    color: var(--text);
  }

  .card-actions {
    display: flex;
    justify-content: center;
    align-items: center;
    padding-top: 1.2em;
    border-top: 0.15em dashed rgba(0, 0, 0, 0.15);
    position: relative;
  }

  .card-button {
    position: relative;
    background: #00c2a8 ;
    color: black
    font-size: 0.9em;
    font-weight: 700;
    padding: 0.7em 1.2em;
    border: 0.2em solid var(--text);
    /* border-radius: 0.4em; */
    box-shadow: 0.3em 0.3em 0 var(--shadow-color);
    cursor: pointer;
    transition: all 0.2s ease;
    overflow: hidden;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .card-button::before {
    content: "";
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent 0%,
      #00c2a8 50%,
      transparent 100%
    );
    transition: left 0.6s ease;
  }

  .card-button:hover {
    background: #00c2a8 ;
    transform: translate(-0.1em, -0.1em);
    box-shadow: 0.4em 0.4em 0 var(--shadow-color);
  }

  .card-button:hover::before {
    left: 100%;
  }

  .card-button:active {
    transform: translate(0.1em, 0.1em);
    box-shadow: 0.15em 0.15em 0 var(--shadow-color);
  }

  .dots-pattern {
    position: absolute;
    bottom: 2em;
    left: -2em;
    width: 8em;
    height: 4em;
    opacity: 0.3;
    transform: rotate(-10deg);
    pointer-events: none;
    z-index: 1;
  }

  .accent-shape {
    position: absolute;
    width: 2.5em;
    height: 2.5em;
    background: var(--secondary);
    border: 0.15em solid var(--text);
    border-radius: 0.3em;
    transform: rotate(45deg);
    bottom: -1.2em;
    right: 2em;
    z-index: 0;
    transition: transform 0.3s ease;
  }

  .card-contact:hover .accent-shape {
    transform: rotate(55deg) scale(1.1);
  }

  .corner-slice {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 1.5em;
    height: 1.5em;
    background: var(--bg);
    border-right: 0.25em solid var(--text);
    border-top: 0.25em solid var(--text);
    border-radius: 0 0.5em 0 0;
    z-index: 1;
  }
</style> 