<style>
  body {
    background: #e0e0e0;
    margin: 0;
    font-family: sans-serif;
  }

  /* NAVBAR */
  header {
    display: flex;
    justify-content: center;
    padding: 20px;
  }

  nav {
    width: 90%;
    max-width: 900px;
    border-radius: 30px;
    background: #e0e0e0;
    box-shadow: 
      15px 15px 30px #bebebe,
      -15px -15px 30px #ffffff;
    padding: 15px 30px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-weight: bold;
    font-size: 18px;
  }

  ul {
    list-style: none;
    display: flex;
    gap: 20px;
    padding: 0;
    margin: 0;
  }

  li a {
    text-decoration: none;
    color: #333;
    padding: 10px 15px;
    border-radius: 15px;
    transition: all 0.2s ease;
    box-shadow: 
      5px 5px 10px #bebebe,
      -5px -5px 10px #ffffff;
  }

  /* efecto neumórfico hover */
  li a:hover {
    box-shadow: 
      inset 5px 5px 10px #bebebe,
      inset -5px -5px 10px #ffffff;
  }

  /* botón CTA */
  .cta {
    padding: 10px 20px;
    border-radius: 20px;
    background: #e0e0e0;
    box-shadow: 
      5px 5px 10px #bebebe,
      -5px -5px 10px #ffffff;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .cta:hover {
    box-shadow: 
      inset 5px 5px 10px #bebebe,
      inset -5px -5px 10px #ffffff;
  }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    nav {
      flex-direction: column;
      gap: 15px;
    }

    ul {
      flex-wrap: wrap;
      justify-content: center;
    }
  }

  /* CARD (la tuya original para contexto) */
  .container {
    display: flex;
    justify-content: center;
    align-items: center;
    height: calc(100vh - 120px);
  }

  .card {
    width: 190px;
    height: 254px; 
    border-radius: 30px;
    background: #e0e0e0;
    box-shadow: 
      15px 15px 30px #bebebe,
      -15px -15px 30px #ffffff;
  }
</style>

<header>
  <nav>
    <div class="logo">Carlos.dev</div>

    <ul>
      <li><a href="#">Inicio</a></li>
      <li><a href="#">Sobre mí</a></li>
      <li><a href="#">Proyectos</a></li>
      <li><a href="#">Skills</a></li>
      <li><a href="#">Contacto</a></li>
    </ul>

    <div class="cta">CV</div>
  </nav>
</header>

<div class="container">
  <div class="card"></div>
</div>
