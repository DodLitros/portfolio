---
// BottomNav.astro — Neobrutalista
// Los tabs emergen desde abajo (translateY), hover los sube más
// Scroll down → se van hacia abajo, scroll up → vuelven
---

<nav class="bottom-nav" id="bottom-nav">
  <div class="nav-inner">
    <a href="/proyectos" class="nav-item c1" data-label="Proyectos">
      <span>Proyectos</span>
    </a>
    <a href="#experiencia" class="nav-item c2" data-label="Experiencia"
      ><span>Experiencia</span></a
    >
    <a href="/planes" class="nav-item c3" data-label="Planes">
      <span>Planes</span>
    </a>
    <a href="/skills" class="nav-item c4" data-label="Skills">
      <span>Skills</span>
    </a>
    <a href="/contactame" class="nav-item c5" data-label="Contáctame"
      ><span>Contáctame</span>
    </a>
  </div>
</nav>

<style>
  :root {
    --nb: #0d0d0d;
    --bw: 3px;
    --sh: 5px;
    --c1: #ffe600;
    --c2: #ff6b35;
    --c3: #00c2a8;
    --c4: #c084fc;
    --c5: #ff3c00;
    --c1h: #f7d700;
    --c2h: #e85520;
    --c3h: #00a892;
    --c4h: #a855f7;
    --c5h: #cc2f00;
  }

  .bottom-nav {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    display: flex;
    justify-content: center;
    align-items: flex-end;
    pointer-events: none;
    transform: translateY(0%);
    transition: transform 0.45s cubic-bezier(0.23, 1, 0.32, 1);
    will-change: transform;
  }

  .bottom-nav.hidden {
    transform: translateY(110%);
  }

  .nav-inner {
    display: flex;
    align-items: flex-end;
    gap: 6px;
    padding: 0 20px;
    pointer-events: auto;
  }

  .nav-item {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: var(--nb);
    font-family: "Pixelify Sans", sans-serif;
    font-weight: 700;
    font-size: clamp(0.68rem, 1.2vw, 0.85rem);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    white-space: nowrap;
    padding: 10px 18px 50px 20px;
    border: var(--bw) solid var(--nb);
    border-bottom: none;
    box-shadow: var(--sh) calc(var(--sh) * -1) 0 0 var(--nb);
    /* Estado base: emergiendo un poco desde abajo */
    transform: translateY(0%);
    transform-origin: bottom center;
    transition:
      transform 0.22s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.18s ease,
      background 0.15s ease,
      color 0.15s ease;
    cursor: pointer;
  }

  .c1 {
    background: var(--c1);
  }
  .c2 {
    background: var(--c2);
    color: #fff;
  }
  .c3 {
    background: var(--c3);
  }
  .c4 {
    background: var(--c4);
  }
  .c5 {
    background: var(--c5);
  }

  /* Hover: sube en dirección de la flecha */
  .nav-item:hover {
    transform: translateY(-20px);
    box-shadow: 7px -7px 0 0 var(--nb);
  }

  .c1:hover {
    background: var(--c1h);
  }
  .c2:hover {
    background: var(--c2h);
  }
  .c3:hover {
    background: var(--c3h);
  }
  .c4:hover {
    background: var(--c4h);
  }
  .c5:hover {
    background: var(--c5h);
  }

  .nav-item:active {
    transform: translateY(-4px);
    box-shadow: 2px -2px 0 0 var(--nb);
    transition-duration: 0.06s;
  }

  .nav-item:focus-visible {
    outline: 3px dashed var(--nb);
    outline-offset: 3px;
  }

  /* Sección activa: ligeramente elevada */
  .nav-item.active {
    transform: translateY(-4px);
    box-shadow: 6px -6px 0 0 var(--nb);
  }

  @media (max-width: 600px) {
    .nav-inner {
      gap: 4px;
      padding: 0 8px;
    }
    .nav-item {
      padding: 8px 10px 10px;
      font-size: 0.62rem;
    }
    .c5 {
      padding: 8px 12px 10px;
    }
  }
</style>

<script>
  const nav = document.getElementById("bottom-nav")!;
  let lastY = window.scrollY;
  let ticking = false;

  window.addEventListener(
    "scroll",
    () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const y = window.scrollY;
          if (y > lastY && y > 60) nav.classList.add("hidden");
          else nav.classList.remove("hidden");
          lastY = y;
          ticking = false;
        });
        ticking = true;
      }
    },
    { passive: true },
  );

  document.querySelectorAll<HTMLAnchorElement>(".nav-item").forEach((link) => {
    link.addEventListener("click", (e) => {
      const href = link.getAttribute("href");
      if (!href?.startsWith("#")) return;
      const target = document.querySelector(href);
      if (!target) return;
      e.preventDefault();
      target.scrollIntoView({ behavior: "smooth", block: "start" });
    });
  });

  const links = document.querySelectorAll<HTMLAnchorElement>(".nav-item");
  const ids = [
    "#proyectos",
    "#experiencia",
    "#planes",
    "#skills",
    "#contactame",
  ];
  const secs = ids
    .map((id) => document.querySelector(id))
    .filter(Boolean) as Element[];

  const obs = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = "#" + entry.target.id;
          links.forEach((l) =>
            l.classList.toggle("active", l.getAttribute("href") === id),
          );
        }
      });
    },
    { rootMargin: "0px 0px -55% 0px", threshold: 0 },
  );

  secs.forEach((s) => obs.observe(s));
</script>