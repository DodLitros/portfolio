---

<div class="wrapper">
  <div class="inner" style="--quantity: 5;">
    <div class="card" style="--index: 0;--color-card: #ffe600;">
      <div class="img"></div>
      <p class="project__tittle">ETL</p>
    </div>
    <div class="card" style="--index: 1;--color-card: #ff6b35;">
      <div class="img"></div>
      <p class="project__tittle">Therapy time</p>
    </div>
    <div class="card" style="--index: 2;--color-card: #00c2a8;">
      <div class="img"></div>
      <p class="project__tittle">Star wars blog</p>
    </div>
    <div class="card" style="--index: 3;--color-card: #c084fc;">
      <div class="img"></div>
      <p class="project__tittle">Simulador crediticio</p>
    </div>
    <div class="card" style="--index: 4;--color-card: #ff0000;">
      <div class="img"></div>
      <p class="project__tittle">Proyect Dashboard</p>
    </div>
  </div>
</div>

<style>
  .wrapper {
    width: 100%;
    height: 100%;
    position: relative;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .inner {
    --w: 120px;
    --h: 180px;
    --translateZ: calc((var(--w) + var(--h)) + 0px);
    --rotateX: -15deg;
    --perspective: 1000px;
    position: absolute;
    width: var(--w);
    height: var(--h);
    top: 25%;
    left: calc(50% - (var(--w) / 2) - 2.5px);
    z-index: 2;
    transform-style: preserve-3d;
    transform: perspective(var(--perspective));
    animation: rotating 15s linear infinite; 
  }
  @keyframes rotating {
    from {
      transform: perspective(var(--perspective)) rotateX(var(--rotateX))
        rotateY(0);
    }
    to {
      transform: perspective(var(--perspective)) rotateX(var(--rotateX))
        rotateY(1turn);
    }
  }

  .card {
    display: flex;
    flex-direction: column;
    position: absolute;
    border: 3px solid black;
    border-radius: 12px;
    overflow: hidden;
    inset: 0;
    transform: rotateY(calc((360deg / var(--quantity)) * var(--index)))
      translateZ(var(--translateZ));
    cursor: pointer;
    
    background: var(--color-card);
  }
  .inner:hover,
  .inner:active {
    animation-play-state: paused;
  }
  .img {
    width:auto;
    height: 100%;
    background-color: white;
    margin: 10px;
    border: 2px solid black;
    object-fit: cover;
  }
  .project__tittle{
    font-family: "Pixelify Sans", sans-serif;
    font-weight: 600;
    font-size: 1.2rem;
  }
</style>
