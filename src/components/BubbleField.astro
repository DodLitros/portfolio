---

<div class="bubble-grid">
  {
    bubbles.map((b) => (
      <div class="grid-cell">
        <div
          class="bubble-wrapper"
          style={`
            --rand-x: ${Math.floor(Math.random() * 80 - 20)}px; 
            --rand-y: ${Math.floor(Math.random() * 40 - 20)}px;
            --delay: ${b.delay}s;
          `}
        >
          <Bubble {...b} />
        </div>
      </div>
    ))
  }
</div>

<style>
  .bubble-grid {
    display: grid;
    /* Crea columnas automáticas. Ajusta el 120px según el tamaño de tu burbuja */
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 1rem;
    width: 100%;
    height: 100%;
    padding-top: 50px;
    max-width: 1200px; /* Opcional: para que no se estire infinito */
    justify-items: center;
    align-items: center;
  }

  .grid-cell {
    position: relative;
    width: 1%;
    height: 50px; /* Altura fija para que el grid sea simétrico */
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .bubble-wrapper {
    position: relative;
    /* Aplicamos el desplazamiento aleatorio aquí */
    transform: translate(var(--rand-x), var(--rand-y));
    /* Añadimos un pequeño delay a la animación de flotar para que no todas suban a la vez */
    animation-delay: var(--delay);
  }
</style>