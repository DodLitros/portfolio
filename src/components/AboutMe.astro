---
interface Props {
  title?: string;
}

const { title = "acerca de mi" } = Astro.props;
---


<div class="main-layout">      
      <div class="header-box">
        <h2 class="title">{title}</h2>
      </div>
      <div class="description-area bento-box grey-bg">
        <div class="inner-text">
            <slot name="description" />
        </div>
      </div>
    </div>
  </div>

<style>
  /* Variables de tu paleta */
  :root {
    --orange: #FF4F00;
    --light-grey: #D9D9D9;
    --blue: #0E4C92;
    --dark-grey: #C0C0C0;
    --black: #222222;
    --neo-shadow: 8px 8px 0px var(--black);
  }

  .about-container {
    padding: 2rem;
    font-family: 'Inter', 'system-ui', sans-serif;
  }

  /* Título Neobrutalista */
  .header-box {
    z-index: 2;
    position: relative;
    display: inline-block;
    background: var(--orange);
    padding: 0.5rem 2rem;
    border: 4px solid var(--black);
    box-shadow: var(--neo-shadow);
    margin-bottom: 2rem;
    transform: rotate(-5deg); /* Toque rebelde */
  }

  .title {
    color: white;
    text-transform: uppercase;
    font-weight: 900;
    font-size: 1.5rem;
    margin: 0;
    text-shadow: 3px 3px 0px var(--black);
  }

  /* Layout de Bento Grid */
  .content-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    grid-template-rows: auto auto;
    gap: 1.5rem;
  }

  /* Estilo base de las cajas Neobrutalistas */
  .bento-box {
    border: 4px solid var(--black);
    box-shadow: var(--neo-shadow);
    transition: all 0.2s ease;
    position: relative;
  }

  .bento-box:hover {
    transform: translate(-2px, -2px);
    box-shadow: 10px 10px 0px var(--black);
  }

  /* Colores de fondo específicos */
  .blue-bg { background-color: var(--blue); min-height: 350px; }
  .orange-bg { background-color: var(--orange); }
  .grey-bg { background-color: var(--light-grey); grid-column: span 2; }

  /* Áreas del Grid */
  .visual-area { grid-area: 1 / 1 / 2 / 2; }
  .extra-area { grid-area: 1 / 2 / 2 / 3; }
  .description-area {
    position: relative;
    top: -50px;
    grid-area: 2 / 1 / 3 / 3;
    padding: 2rem;
    min-height: 150px;
  }

  .inner-text {
    font-size: 1.2rem;
    line-height: 1.5;
    color: var(--black);
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .content-grid {
      grid-template-columns: 1fr;
    }
    .visual-area, .extra-area, .description-area {
      grid-column: span 1;
      grid-area: auto;
    }
  }
</style>